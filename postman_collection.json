            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1\n}"
            },
            "url": {
              "raw": "http://localhost:8081/api/posts/1/like",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["api", "posts", "1", "like"]
            }
