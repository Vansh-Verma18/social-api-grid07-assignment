{
  "info": {
    "name": "Social API - Grid07 Assignment (Port 8081)",
    "description": "API collection for testing the Social API with Redis guardrails - Running on port 8081",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Posts",
      "item": [
        {
          "name": "Create Post",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"authorId\": 1,\n  \"content\": \"This is my first post about Spring Boot and Redis!\"\n}"
            },
            "url": {
              "raw": "http://localhost:8081/api/posts",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["api", "posts"]
            }
          },
          "response": []
        },
        {
          "name": "Like Post",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
